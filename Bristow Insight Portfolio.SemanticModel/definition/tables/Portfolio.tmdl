	column 'Section Sort' = SWITCH('Portfolio'[Section], "Active Development", 1, "Pipeline", 2, "Production", 3)
		dataType: int64
		isHidden
		lineageTag: 0cd50a34-8e6e-446b-a5f2-f9b60e35e264

	column 'Section Icon Label' = SWITCH('Portfolio'[Section], "Active Development", UNICHAR(9654) & "  Active Development", "Pipeline", UNICHAR(9675) & "  Pipeline", "Production", UNICHAR(9679) & "  Production")
		dataType: string
		lineageTag: b178a39a-38ae-4c80-ab29-64aed1e9dd23
		sortByColumn: 'Section Sort'

	column 'Phase Display' = IF('Portfolio'[Phase Number] < 5, 'Portfolio'[Lifecycle Phase] & " [" & FORMAT('Portfolio'[Phase Number], "0") & "/4]", "Production")
		dataType: string
		lineageTag: 937ce23a-7237-4772-8cf0-f2ba7651b7ba
		sortByColumn: 'Phase Number'

	column 'Active Tasks Display' = IF(ISBLANK('Portfolio'[Active Tasks]) || 'Portfolio'[Active Tasks] = "", "No active tasks — stable operations", SUBSTITUTE('Portfolio'[Active Tasks], " | ", UNICHAR(10)))
		dataType: string
		lineageTag: fa31c90b-42b7-4172-bd47-693de03911f7

	partition Portfolio = m
		mode: import
		source =
