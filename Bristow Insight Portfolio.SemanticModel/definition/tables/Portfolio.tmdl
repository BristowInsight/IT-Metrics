table Portfolio
	lineageTag: 9d4c832a-ca49-488a-a371-bfa0d8852b3e

	measure 'Product Count' = COUNTROWS('Portfolio')
		formatString: 0
		lineageTag: 8e40fbba-af23-4b96-b026-8f24f822c2fe

	measure 'Active Dev Count' = CALCULATE([Product Count], 'Portfolio'[Section] = "Active Development")
		formatString: 0
		lineageTag: fe07d428-4974-49ae-8021-e6ca7101df50

	measure 'Pipeline Count' = CALCULATE([Product Count], 'Portfolio'[Section] = "Pipeline")
		formatString: 0
		lineageTag: 32b80bf6-7be2-4f40-8c32-cc8a9e49b556

	measure 'Production Count' = CALCULATE([Product Count], 'Portfolio'[Section] = "Production")
		formatString: 0
		lineageTag: 957726c8-79d1-4d0e-a2cf-b29bc9823c96

	measure 'Primary Count' = CALCULATE([Product Count], 'Portfolio'[Priority] = "Primary")
		formatString: 0
		lineageTag: 0621e4f0-84f2-47e5-9898-56198e36a318

	measure 'Secondary Count' = CALCULATE([Product Count], 'Portfolio'[Priority] = "Secondary")
		formatString: 0
		lineageTag: b1e6c45e-7561-4c97-b450-a67ec1fe4f36

	measure 'Programs Served' = DISTINCTCOUNT('Portfolio'[Program])
		formatString: 0
		lineageTag: 9a823fa7-230f-4095-a625-8db7bcfdbbe2

	measure 'Strategic Priorities Covered' = DISTINCTCOUNT('Portfolio'[Strategic Alignment])
		formatString: 0
		lineageTag: 018251ac-8ed3-4d39-94cf-21a6d6384031

	measure '_Section BG Color' = SWITCH(SELECTEDVALUE('Portfolio'[Section]), "Active Development", "#FFF7F0", "Pipeline", "#F2F2F2", "Production", "#F6FAFD", "#FFFFFF")
		isHidden
		lineageTag: 7ea3154d-0e89-47b7-a646-b16cdbfb107e

	measure '_Section Header BG' = SWITCH(SELECTEDVALUE('Portfolio'[Section]), "Active Development", "#FBE5D6", "Pipeline", "#E5E5E5", "Production", "#D6E4F0", "#FFFFFF")
		isHidden
		lineageTag: 50042ea4-7957-450f-8120-75103a4feac2

	measure '_Section Header FG' = SWITCH(SELECTEDVALUE('Portfolio'[Section]), "Active Development", "#D4712A", "Pipeline", "#6B6B6B", "Production", "#3680C4", "#000000")
		isHidden
		lineageTag: 8aa9fceb-134a-44cd-b625-de69002beb6e

	measure '_Priority Color' = SWITCH(SELECTEDVALUE('Portfolio'[Priority]), "Primary", "#D4712A", "Secondary", "#6B6B6B", "#8A8A8A")
		isHidden
		lineageTag: 2cb87331-bad1-47ab-85f4-dc9adac92f80

	measure '_Active Tasks FG' = IF(SELECTEDVALUE('Portfolio'[Active Tasks Display]) = "No active tasks — stable operations", "#8A8A8A", "#000000")
		isHidden
		lineageTag: 3340b24e-823c-436f-8e8c-39e202e6f857

	measure '_Row BG Color' =
		VAR _IsProduct = ISINSCOPE('Portfolio'[Product])
		VAR _IsSection = ISINSCOPE('Portfolio'[Section Icon Label]) && NOT _IsProduct
		VAR _IsProgram = ISINSCOPE('Portfolio'[Program]) && NOT ISINSCOPE('Portfolio'[Section Icon Label])
		RETURN
		IF(_IsProgram, "#1B305A",
		IF(_IsSection, [_Section Header BG],
		IF(_IsProduct, [_Section BG Color],
		"#FFFFFF")))
		isHidden
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567890

	measure '_Row FG Color' =
		VAR _IsProduct = ISINSCOPE('Portfolio'[Product])
		VAR _IsSection = ISINSCOPE('Portfolio'[Section Icon Label]) && NOT _IsProduct
		VAR _IsProgram = ISINSCOPE('Portfolio'[Program]) && NOT ISINSCOPE('Portfolio'[Section Icon Label])
		RETURN
		IF(_IsProgram, "#FFFFFF",
		IF(_IsSection, [_Section Header FG],
		IF(_IsProduct, "#323130",
		"#000000")))
		isHidden
		lineageTag: b2c3d4e5-f6a7-8901-bcde-f12345678901

